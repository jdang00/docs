{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "LearnTerms Docs",
  "colors": {
    "primary": "#422AD5",
    "light": "#605DFF",
    "dark": "#F43098"
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#1D232A"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "onboarding",
              "platform/architecture-and-data-model"
            ]
          },
          {
            "group": "Students",
            "pages": [
              "students/classes-and-modules",
              "students/study-flow",
              "students/custom-tests"
            ]
          },
          {
            "group": "Admins",
            "pages": [
              "admin/admin-dashboard",
              "admin/content-library",
              "admin/question-studio"
            ]
          },
          {
            "group": "Contributors",
            "pages": [
              "contributors/question-authoring"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "platform/roles-and-permissions"
            ]
          },
          {
            "group": "Docs Site",
            "pages": [
              "quickstart",
              "development"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "LearnTerms",
          "href": "https://www.learnterms.com"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/jdang00/learnterms"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "",
        "href": "https://www.learnterms.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open LearnTerms",
      "href": "https://www.learnterms.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jdang00/learnterms"
    }
  },
  "fonts": {
    "family": "Geist"
  }
}
